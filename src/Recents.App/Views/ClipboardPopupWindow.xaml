<Window x:Class="Recents.App.Views.ClipboardPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Recents.App.ViewModels"
        xmlns:loc="clr-namespace:Recents.App.Localization"
        Title="Pop Paste"
        Width="600" Height="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{DynamicResource TextPrimary}"
        FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Border Background="{DynamicResource BgMain}"
            BorderBrush="{DynamicResource AccentBlue}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" Direction="270" ShadowDepth="3" Opacity="0.45"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="8" BorderThickness="1"
                    Background="{DynamicResource BgInput}"
                    BorderBrush="{DynamicResource BorderMuted}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe Fluent Icons"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextTertiary}"/>
                    <TextBox x:Name="SearchBox" Grid.Column="1"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource TextPrimary}"
                             CaretBrush="{DynamicResource TextPrimary}"
                             VerticalContentAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="SearchBox_KeyDown"/>
                </Grid>
            </Border>

            <ListBox x:Name="ItemsList" Grid.Row="1"
                     Margin="0,12,0,8"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemsSource="{Binding ItemsView}"
                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                     MouseDoubleClick="ItemsList_MouseDoubleClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="8,7"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ClipboardItemViewModel}">
                        <Grid MinHeight="42">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="34" Height="34" CornerRadius="6"
                                    Background="{DynamicResource BgInput}" Margin="0,0,10,0">
                                <TextBlock Text="{Binding TypeIcon}" FontFamily="Segoe Fluent Icons"
                                           FontSize="15" Foreground="{DynamicResource TextSecondary}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding PreviewText}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Metadata}" FontSize="11"
                                           Foreground="{DynamicResource TextTertiary}"
                                           Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="2">
                <TextBlock Text="{loc:T Key=PopPaste_Hint}" FontSize="11"
                           Foreground="{DynamicResource TextTertiary}"
                           VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                           Text="{Binding ItemsView.Count, StringFormat={}{0} items}"
                           FontSize="11" Foreground="{DynamicResource TextTertiary}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
