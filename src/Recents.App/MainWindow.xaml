<Window x:Class="Recents.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Recents.App.ViewModels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:utils="clr-namespace:Recents.App.Utils"
        xmlns:loc="clr-namespace:Recents.App.Localization"
        xmlns:helpers="clr-namespace:Recents.App.Helpers"
        mc:Ignorable="d"
        Title="{loc:T Key=Main_Title}" Height="760" Width="600" MinHeight="520" MinWidth="600"
        WindowStartupLocation="CenterScreen" 
        Topmost="True" ShowInTaskbar="False"
        Background="Transparent" Foreground="{DynamicResource TextPrimary}"
        AllowsTransparency="True"
        FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
        WindowStyle="None"
        Icon="pack://application:,,,/Recents;component/Resources/Icons/AppIcon.ico"
        PreviewKeyDown="Window_PreviewKeyDown"
        SizeChanged="Window_SizeChanged"
        Closing="Window_Closing">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="8" ResizeBorderThickness="8" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <utils:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <utils:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <utils:BooleanToColorConverter x:Key="BooleanToColorConverter" />

        <Style x:Key="HidingMenuItem" TargetType="MenuItem">
            <EventSetter Event="Click" Handler="MenuItem_Click"/>
        </Style>

        <!-- ListBoxItem Style -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <StackPanel>
                            <Border x:Name="OuterBorder" Background="{TemplateBinding Background}" CornerRadius="8" Margin="12,1" BorderThickness="1" BorderBrush="Transparent">
                                <ContentPresenter />
                            </Border>
                            <Rectangle Height="1" Fill="{DynamicResource BorderMuted}" Margin="16,1" Opacity="0.8" SnapsToDevicePixels="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource RowHover}" />
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource BorderMuted}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource RowSelected}" />
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource AccentBlue}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FavoritesItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="OuterBorder" Background="{TemplateBinding Background}" CornerRadius="8" Margin="4,1" BorderThickness="1" BorderBrush="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource RowHover}" />
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource BorderMuted}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource RowSelected}" />
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource AccentBlue}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Control Button -->
        <Style x:Key="WindowControlBtn" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Content}" FontFamily="Segoe Fluent Icons" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RowHover}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" Background="{TemplateBinding Background}" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{DynamicResource TextTertiary}" CornerRadius="5" Margin="2,0" Opacity="0.5" />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="FavoritesItemTemplate" DataType="{x:Type vm:RecentItemViewModel}">
            <Grid Margin="2,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />   <!-- drag handle (edit mode only) -->
                    <ColumnDefinition Width="Auto" />   <!-- 24px icon -->
                    <ColumnDefinition Width="*" />      <!-- display name -->
                    <ColumnDefinition Width="Auto" />   <!-- unpin button (edit mode only) -->
                </Grid.ColumnDefinitions>

                <!-- drag handle: visible in edit mode only; Border avoids mouse capture so ListBox.MouseMove fires -->
                <Border Grid.Column="0" Width="24" Height="32" Cursor="SizeNS"
                        Background="Transparent"
                        PreviewMouseLeftButtonDown="FavoritesDragHandle_PreviewMouseLeftButtonDown">
                    <TextBlock Text="&#xE784;" FontFamily="Segoe Fluent Icons" FontSize="14"
                               Foreground="{DynamicResource TextTertiary}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsFavoritesEditMode,
                                             RelativeSource={RelativeSource AncestorType=Window}}"
                                             Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <Image Grid.Column="1" Source="{Binding SmallIcon}" Width="24" Height="24"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>

                <TextBlock Grid.Column="2" Text="{Binding FavoriteDisplayName}" FontWeight="SemiBold"
                           FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                           ToolTip="{Binding FavoriteToolTip}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource ColorDanger}"/>
                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- unpin button: visible in edit mode -->
                <Button Grid.Column="3" Content="&#xE735;" Command="{Binding TogglePinCommand}"
                        FontFamily="Segoe Fluent Icons" Width="28" Height="32"
                        ToolTip="{loc:T Key=Main_Favorites_Unpin}"
                        Foreground="{DynamicResource AccentBlue}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsFavoritesEditMode,
                                             RelativeSource={RelativeSource AncestorType=Window}}"
                                             Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ClipboardItemTemplate" DataType="{x:Type vm:ClipboardItemViewModel}">
            <Grid Margin="4" MinHeight="54">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="6"
                        Background="{DynamicResource BgInput}"
                        BorderBrush="{DynamicResource BorderMuted}"
                        BorderThickness="1"
                        VerticalAlignment="Center" Margin="0,0,14,0">
                    <Grid>
                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                               Visibility="{Binding ThumbnailVisibility}"/>
                        <TextBlock Text="{Binding TypeIcon}" FontFamily="Segoe Fluent Icons"
                                   FontSize="18" Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding IconVisibility}"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border CornerRadius="4" Background="{DynamicResource AccentBlue}"
                                Padding="5,1" Margin="0,0,8,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TypeLabel}" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="{Binding DisplayText}" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{DynamicResource TextPrimary}"
                                   TextTrimming="CharacterEllipsis" MaxWidth="360"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Metadata}" FontSize="11"
                               Foreground="{DynamicResource TextTertiary}"
                               TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&#xE8C8;" Command="{Binding CopyCommand}"
                            FontFamily="Segoe Fluent Icons" Style="{StaticResource ActionButtonStyle}"
                            Width="32" Height="32" ToolTip="{loc:T Key=Clipboard_Action_Copy}"/>
                    <Button Content="&#xE735;" Command="{Binding ToggleFavoriteCommand}"
                            FontFamily="Segoe Fluent Icons" Width="32" Height="32" ToolTip="{loc:T Key=Clipboard_Action_ToggleFavorite}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Item.IsFavorite}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="&#xE74D;" Command="{Binding DeleteCommand}"
                            FontFamily="Segoe Fluent Icons" Style="{StaticResource ActionButtonStyle}"
                            Width="32" Height="32" ToolTip="{loc:T Key=Clipboard_Action_Delete}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ClipboardFavoriteItemTemplate" DataType="{x:Type vm:ClipboardFavoriteViewModel}">
            <Grid Margin="2,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="24" Height="32" Cursor="SizeNS"
                        Background="Transparent"
                        PreviewMouseLeftButtonDown="FavoritesDragHandle_PreviewMouseLeftButtonDown">
                    <TextBlock Text="&#xE784;" FontFamily="Segoe Fluent Icons" FontSize="14"
                               Foreground="{DynamicResource TextTertiary}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsFavoritesEditMode,
                                             RelativeSource={RelativeSource AncestorType=Window}}"
                                             Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <Border Grid.Column="1" Width="24" Height="24" CornerRadius="5"
                        Background="{DynamicResource BgInput}"
                        VerticalAlignment="Center" Margin="0,0,8,0">
                    <Grid>
                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                               Visibility="{Binding ThumbnailVisibility}"/>
                        <TextBlock Text="{Binding TypeIcon}" FontFamily="Segoe Fluent Icons" FontSize="13"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding IconVisibility}"/>
                    </Grid>
                </Border>

                <TextBlock Grid.Column="2" Text="{Binding DisplayName}" FontWeight="SemiBold"
                           FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                           ToolTip="{Binding FavoriteToolTip}"
                           Foreground="{DynamicResource TextPrimary}"/>

                <Button Grid.Column="3" Content="&#xE735;" Command="{Binding RemoveFavoriteCommand}"
                        FontFamily="Segoe Fluent Icons" Width="28" Height="32"
                        ToolTip="{loc:T Key=Main_Favorites_Unpin}"
                        Foreground="{DynamicResource AccentBlue}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsFavoritesEditMode,
                                             RelativeSource={RelativeSource AncestorType=Window}}"
                                             Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="FavoriteGroupTemplate" DataType="{x:Type vm:FavoriteGroupViewModel}">
            <Grid Margin="0,6,0,2" MinHeight="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="24" Height="28" Cursor="SizeNS"
                        Background="Transparent"
                        PreviewMouseLeftButtonDown="FavoritesDragHandle_PreviewMouseLeftButtonDown">
                    <TextBlock Text="&#xE784;" FontFamily="Segoe Fluent Icons" FontSize="14"
                               Foreground="{DynamicResource TextTertiary}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsFavoritesEditMode,
                                             RelativeSource={RelativeSource AncestorType=Window}}"
                                             Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <Button Grid.Column="1" Content="{Binding CollapseIcon}"
                        Command="{Binding ToggleCollapsedCommand}"
                        FontFamily="Segoe Fluent Icons" FontSize="10"
                        Style="{StaticResource ActionButtonStyle}"
                        Width="24" Height="24"
                        ToolTip="{loc:T Key=Main_Favorites_Group_Toggle}"/>

                <TextBlock Grid.Column="2" Text="{Binding Name}"
                           FontSize="11" FontWeight="Bold"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"
                           Margin="2,0,6,0"/>

                <Grid Grid.Column="3" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ItemCountText}" FontSize="10"
                               Foreground="{DynamicResource TextTertiary}"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsFavoritesEditMode,
                                                 RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsFavoritesEditMode,
                                                 RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Content="&#xE70F;" Command="{Binding RenameCommand}"
                                FontFamily="Segoe Fluent Icons" FontSize="11"
                                Style="{StaticResource ActionButtonStyle}"
                                Width="24" Height="24"
                                ToolTip="{loc:T Key=Main_Favorites_Group_Rename}"/>
                        <Button Content="&#xE74D;" Command="{Binding DeleteCommand}"
                                FontFamily="Segoe Fluent Icons" FontSize="11"
                                Style="{StaticResource ActionButtonStyle}"
                                Width="24" Height="24"
                                ToolTip="{loc:T Key=Main_Favorites_Group_Delete}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </DataTemplate>

        <helpers:MainItemTemplateSelector x:Key="MainItemTemplateSelector"
                                          RecentTemplate="{StaticResource SharedRecentItemTemplate}"
                                          ClipboardTemplate="{StaticResource ClipboardItemTemplate}"/>
        <helpers:FavoritesItemTemplateSelector x:Key="FavoritesItemTemplateSelector"
                                               RecentTemplate="{StaticResource FavoritesItemTemplate}"
                                               ClipboardTemplate="{StaticResource ClipboardFavoriteItemTemplate}"
                                               GroupTemplate="{StaticResource FavoriteGroupTemplate}"/>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="1" 
            Background="{DynamicResource BgMain}" CornerRadius="8" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" RenderingBias="Quality" ShadowDepth="1" Opacity="0.4" Color="{DynamicResource WindowShadowColor}"/>
        </Border.Effect>
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Pre-warm Segoe Fluent Icons: WPF lazily loads non-system fonts.
             Without this, the first ContextMenu open in the Popup HWND may render
             before glyph data is available, showing blank icons.
             Visibility=Hidden participates in layout/render (unlike Collapsed) 
             ensuring glyphs are cached before any ContextMenu opens. -->
        <TextBlock Visibility="Hidden" Width="1" Height="1" Grid.Column="0"
                   FontFamily="Segoe Fluent Icons" FontSize="14" IsHitTestVisible="False"
                   Text="&#xED25;&#xE7BC;&#xE81D;&#xE8C8;&#xE735;&#xE894;&#xE74D;&#xE713;&#xE921;&#xE922;&#xE8BB;"/>

        <!-- Main Content -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" /> <!-- Custom Title Bar Row -->
                <RowDefinition Height="Auto" /> <!-- Search Row -->
                <RowDefinition Height="Auto" /> <!-- Filter Row -->
                <RowDefinition Height="*" /> <!-- List Row -->
                <RowDefinition Height="40" /> <!-- Status Bar Row -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar Controls -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <!-- Toggle Favorites Drawer -->
                <ToggleButton Style="{StaticResource ActionToggleButtonStyle}" Padding="8" Margin="0,0,4,0"
                              IsChecked="{Binding IsFavoritesDrawerOpen}"
                              Visibility="{Binding HasFavorites, Converter={StaticResource BooleanToVisibilityConverter}}"
                              ToolTip="{loc:T Key=Main_Favorites_Toggle}">
                    <TextBlock Text="&#xE735;" FontFamily="Segoe Fluent Icons" FontSize="14" 
                               Foreground="{Binding IsFavoritesDrawerOpen, Converter={StaticResource BooleanToColorConverter}, ConverterParameter=AccentBlue}"/>
                </ToggleButton>

                <Button Content="&#xE921;" Style="{StaticResource WindowControlBtn}" Click="MinimizeBtn_Click"/>
                <Button Content="&#xE922;" Style="{StaticResource WindowControlBtn}" Click="MaximizeBtn_Click"/>
                <Button Content="&#xE8BB;" Click="CloseBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource WindowControlBtn}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ColorDanger}" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- App Logo & Title in Row 0 Left -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Image Width="20" Height="20" Source="pack://application:,,,/Recents;component/Resources/Icons/AppIcon.ico" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="{loc:T Key=Main_Title}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>

                <!-- Settings Button -->
                <Button Style="{StaticResource WindowControlBtn}" Width="32" Height="32" Content="&#xE713;" ToolTip="{loc:T Key=Main_Tooltip_Settings}" Click="Settings_Click"/>
            </StackPanel>

            <!-- Search Area -->
            <Grid Grid.Row="1" Margin="24,10,24,10">
                <Border CornerRadius="8" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource BgInput}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderMuted}" />
                            <Style.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{DynamicResource TextTertiary}"/>
                        <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}" VerticalContentAlignment="Center" FontSize="14" Padding="0,10"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 x:Name="SearchBox" KeyDown="SearchBox_KeyDown" />
                        <TextBlock Grid.Column="1" Text="{loc:T Key=Main_Search_Placeholder}" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text.IsEmpty, ElementName=SearchBox}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,10,0">
                            <Button Content="&#xE711;"
                                    Command="{Binding ClearSearchCommand}"
                                    FontFamily="Segoe Fluent Icons"
                                    Width="28" Height="28"
                                    ToolTip="{loc:T Key=Main_Search_Clear}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text.IsEmpty, ElementName=SearchBox}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock Text="{Binding HotkeyDisplay}" Foreground="{DynamicResource TextTertiary}" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Filter Area -->
            <Grid Grid.Row="2" Margin="24,0,24,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="{loc:T Key=Main_Filter_AllFiles}" IsChecked="True" Style="{StaticResource FilterPill}" Checked="Chip_Checked" Tag="All"/>
                    <RadioButton Content="{loc:T Key=Main_Filter_Documents}" Style="{StaticResource FilterPill}" Tag="Documents" Checked="Chip_Checked"/>
                    <RadioButton Content="{loc:T Key=Main_Filter_Images}" Style="{StaticResource FilterPill}" Tag="Images" Checked="Chip_Checked"/>
                    <RadioButton Content="{loc:T Key=Main_Filter_Folders}" Style="{StaticResource FilterPill}" Tag="Folders" Checked="Chip_Checked"/>
                    <Rectangle Width="1" Height="18" Fill="{DynamicResource BorderMuted}" Margin="0,5,8,5"/>
                    <RadioButton Content="{loc:T Key=Main_Filter_Clipboard}" Style="{StaticResource FilterPill}" Tag="Clipboard" Checked="Chip_Checked"/>

                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Density Toggle -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <RadioButton Style="{StaticResource FilterPill}" Padding="6,2" Margin="1,0" Tag="Standard" 
                                     IsChecked="{Binding CurrentDensity, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Standard}"
                                     ToolTip="{loc:T Key=Main_Density_Standard}" Click="Density_Click">
                            <TextBlock Text="&#x25AD;" FontSize="14" VerticalAlignment="Center"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource FilterPill}" Padding="6,2" Margin="1,0" Tag="Compact"
                                     IsChecked="{Binding CurrentDensity, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Compact}"
                                     ToolTip="{loc:T Key=Main_Density_Compact}" Click="Density_Click">
                            <TextBlock Text="&#x2550;" FontSize="14" VerticalAlignment="Center"/>
                        </RadioButton>
                    </StackPanel>

                    <Button Background="Transparent" BorderThickness="0" Padding="8,4" Foreground="{DynamicResource TextSecondary}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                <EventSetter Event="Click" Handler="SortButton_Click"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SortLabel" Text="{loc:T Key=Main_Sort_NewestFirst}" FontSize="12" Margin="0,0,8,0"/>
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe Fluent Icons" FontSize="8" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{loc:T Key=Main_Sort_NewestFirst}" Click="SortItem_Click" Tag="RecentTime"/>
                                <MenuItem Header="{loc:T Key=Main_Sort_NameAZ}" Click="SortItem_Click" Tag="DisplayName"/>
                                <!-- P1: Size and File Type sorting options hidden -->
                                <MenuItem Header="{loc:T Key=Main_Sort_Size}" Click="SortItem_Click" Tag="Size" Visibility="Collapsed"/>
                                <MenuItem Header="{loc:T Key=Main_Sort_Classification}" Click="SortItem_Click" Tag="ClassificationSource" Visibility="Collapsed"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="&#xE8A9;" FontFamily="Segoe Fluent Icons" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextSecondary}" Margin="8,0,0,0" Visibility="Collapsed"/>
                </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0"
                            Visibility="{Binding IsClipboardMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <RadioButton Content="{loc:T Key=Main_ClipSub_All}" IsChecked="True" Style="{StaticResource FilterPill}" Tag="All" Checked="ClipSubChip_Checked"/>
                    <RadioButton Content="{loc:T Key=Main_ClipSub_Text}" Style="{StaticResource FilterPill}" Tag="Text" Checked="ClipSubChip_Checked"/>
                    <RadioButton Content="{loc:T Key=Main_ClipSub_Files}" Style="{StaticResource FilterPill}" Tag="Files" Checked="ClipSubChip_Checked"/>
                    <RadioButton Content="{loc:T Key=Main_ClipSub_Images}" Style="{StaticResource FilterPill}" Tag="Images" Checked="ClipSubChip_Checked"/>
                    <RadioButton Content="{loc:T Key=Main_ClipSub_Html}" Style="{StaticResource FilterPill}" Tag="Html" Checked="ClipSubChip_Checked"/>
                    <RadioButton Content="{loc:T Key=Main_ClipSub_RichText}" Style="{StaticResource FilterPill}" Tag="RichText" Checked="ClipSubChip_Checked"/>
                </StackPanel>
            </Grid>

            <!-- List Area -->
            <Grid Grid.Row="3">
                <!-- Empty State -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasItems}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#xE9CE;" FontFamily="Segoe Fluent Icons" FontSize="48" Foreground="{DynamicResource TextTertiary}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock FontSize="14" Foreground="{DynamicResource TextTertiary}" HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{loc:T Key=Main_Empty_NoFiles}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsInitializing}" Value="True">
                                        <Setter Property="Text" Value="{loc:T Key=Main_Empty_Loading}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0"
                                Visibility="{Binding IsInitializing, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsInitializing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Content="{loc:T Key=Main_Empty_ClearFilters}"
                                Command="{Binding ClearFiltersCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                Padding="12,7" Margin="0,0,8,0"/>
                        <Button Content="{loc:T Key=Main_Empty_RebuildIndex}"
                                Command="{Binding RebuildIndexCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                Padding="12,7"/>
                    </StackPanel>
                </StackPanel>

                <ListBox x:Name="ItemsList" Background="Transparent" BorderThickness="0"
                         SelectionMode="Extended"
                         ItemsSource="{Binding ActiveItemsView}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         VirtualizingPanel.CacheLengthUnit="Item"
                         VirtualizingPanel.CacheLength="10,10"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         MouseDoubleClick="ItemsList_MouseDoubleClick"
                         PreviewMouseWheel="ItemsList_PreviewMouseWheel"
                         PreviewMouseLeftButtonDown="ItemsList_PreviewMouseLeftButtonDown"
                         MouseMove="ItemsList_MouseMove"
                         ContextMenuOpening="ItemsList_ContextMenuOpening">
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasItems}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemTemplateSelector>
                        <StaticResource ResourceKey="MainItemTemplateSelector"/>
                    </ListBox.ItemTemplateSelector>
                </ListBox>

            </Grid>
            
            <!-- Status Bar -->
            <Border Grid.Row="4" Background="{DynamicResource BgCard}" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderMuted}" Padding="20,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{Binding Status.StatusColor}" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Status.StatusText}" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,12,0"/>
                        <Separator Width="1" Height="12" Background="{DynamicResource BorderMuted}" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding Status.ItemCount}" FontSize="12" Foreground="{DynamicResource TextTertiary}"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Status.KeyboardHint}" FontSize="11" Foreground="{DynamicResource TextTertiary}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Right Side Favorites Drawer (Visibility managed in UpdateWindowWidth to avoid flicker) -->
        <Border x:Name="FavoritesDrawer" Grid.Column="1" Background="{DynamicResource BgSidebar}" BorderThickness="1,0,0,0" BorderBrush="{DynamicResource BorderMuted}" Width="160"
                CornerRadius="0,8,8,0"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="8,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="{loc:T Key=Main_Favorites_Header}"
                               FontWeight="Bold" FontSize="11"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="&#xE710;"
                                Command="{Binding AddFavoriteGroupCommand}"
                                FontFamily="Segoe Fluent Icons" FontSize="12"
                                Width="28" Height="28"
                                ToolTip="{loc:T Key=Main_Favorites_AddGroup}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFavoritesEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ToggleFavoritesEditModeCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                Width="Auto" Padding="8,4">
                            <Button.Content>
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondary}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{loc:T Key=Main_Favorites_Edit}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFavoritesEditMode}" Value="True">
                                                    <Setter Property="Text" Value="{loc:T Key=Main_Favorites_Done}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </Grid>

                <ListBox x:Name="FavoritesList" Grid.Row="1" Background="Transparent" BorderThickness="0" ItemsSource="{Binding FavoritesView}" Padding="4"
                         ItemContainerStyle="{StaticResource FavoritesItemStyle}"
                         ItemTemplateSelector="{StaticResource FavoritesItemTemplateSelector}"
                         MouseDoubleClick="FavoritesList_MouseDoubleClick"
                         PreviewMouseLeftButtonDown="FavoritesList_PreviewMouseLeftButtonDown"
                         ContextMenuOpening="FavoritesList_ContextMenuOpening"
                         AllowDrop="True"
                         MouseMove="FavoritesList_MouseMove"
                         DragOver="FavoritesList_DragOver"
                         DragLeave="FavoritesList_DragLeave"
                         Drop="FavoritesList_Drop"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Standard"/>
                <!-- insertion line overlay, shown during edit-mode reorder drag -->
                <Canvas Grid.Row="1" IsHitTestVisible="False" Panel.ZIndex="10">
                    <Border x:Name="FavoritesDragLine"
                            Height="2" Width="{Binding ActualWidth, ElementName=FavoritesList}"
                            Background="{DynamicResource AccentBlue}"
                            CornerRadius="1" Visibility="Collapsed"/>
                </Canvas>
            </Grid>
        </Border>
        </Grid>
    </Border>
</Window>
