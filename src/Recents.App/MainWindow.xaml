<Window x:Class="Recents.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Recents.App.ViewModels"
        mc:Ignorable="d"
        Title="Recents" Height="680" Width="640" MinHeight="480" MinWidth="420"
        WindowStartupLocation="CenterScreen" 
        Topmost="True" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
        PreviewKeyDown="Window_PreviewKeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Fluent Colors (Zinc-like) -->
        <SolidColorBrush x:Key="BgPrimary" Color="#18181B"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#27272A"/>
        <SolidColorBrush x:Key="BorderMuted" Color="#3F3F46"/>
        <SolidColorBrush x:Key="ItemHover" Color="#27272A"/>
        <SolidColorBrush x:Key="ItemSelected" Color="#3F3F46"/>
        
        <SolidColorBrush x:Key="TextPrimary" Color="#F4F4F5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#A1A1AA"/>
        <SolidColorBrush x:Key="TextTertiary" Color="#71717A"/>

        <!-- SearchBox Style -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,20"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid Background="{TemplateBinding Background}">
                            <!-- Placeholder -->
                            <TextBlock Text="Search recent files..." 
                                       Foreground="{StaticResource TextTertiary}"
                                       FontSize="24"
                                       Padding="24,20"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text.IsEmpty, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="8" Margin="12,2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ItemHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ItemSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <!-- Main Panel Drop Shadow -->
        <Border Background="{StaticResource BgPrimary}" 
                CornerRadius="16" 
                BorderBrush="{StaticResource BorderMuted}" 
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="25" ShadowDepth="8" Opacity="0.4" Direction="270"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- SearchBox Area -->
                <TextBox x:Name="SearchBox" Grid.Row="0" Style="{StaticResource SearchBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="SearchBox_KeyDown" />
                
                <Separator Grid.Row="1" Background="{StaticResource BorderMuted}" Margin="0" Height="1" BorderThickness="0"/>

                <!-- ListBox Area -->
                <ListBox x:Name="ItemsList" Grid.Row="2"
                         ItemsSource="{Binding ItemsView}"
                         Background="Transparent" BorderThickness="0" Margin="0,8"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseDoubleClick="ItemsList_MouseDoubleClick"
                         MouseMove="ItemsList_MouseMove">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:RecentItemViewModel}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <Border Grid.Column="0" Width="40" Height="40" Background="{StaticResource BgSecondary}" CornerRadius="8" Margin="0,0,16,0" VerticalAlignment="Center">
                                    <TextBlock Text="📄" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.9"/>
                                </Border>
                                
                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
                                    
                                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                                        <TextBlock Text="{Binding RecentTimeDisplay}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,12,0"/>
                                        <TextBlock Text="{Binding SizeDisplay}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,12,0"/>
                                        <TextBlock Text="{Binding DisplayPath}" Foreground="{StaticResource TextTertiary}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- StatusBar -->
                <Border Grid.Row="3" Background="{StaticResource BgSecondary}" CornerRadius="0,0,15,15" Padding="16,8">
                    <Grid>
                        <TextBlock Text="Ready" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Type to search" Foreground="{StaticResource TextTertiary}" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Arrows to navigate" Foreground="{StaticResource TextTertiary}" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Enter to open" Foreground="{StaticResource TextTertiary}" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
