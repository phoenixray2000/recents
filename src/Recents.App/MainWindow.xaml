<Window x:Class="Recents.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Recents.App.ViewModels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="RecentDock" Height="720" Width="960" MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen" 
        Topmost="True" ShowInTaskbar="True"
        Background="#121214" Foreground="#F8F9FA"
        FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
        WindowStyle="None" AllowsTransparency="False"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="8" ResizeBorderThickness="8" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Color Palette (Refined for RecentDock Mockup) -->
        <SolidColorBrush x:Key="BgSidebar" Color="#1C1C1E" />
        <SolidColorBrush x:Key="BgMain" Color="#1C1C1E" />
        <SolidColorBrush x:Key="BgCard" Color="#2C2C2E" />
        <SolidColorBrush x:Key="BgInput" Color="#2C2C2E" />
        <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6" />
        <SolidColorBrush x:Key="BorderMuted" Color="#38393F" />
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextSecondary" Color="#A1A1AA" />
        <SolidColorBrush x:Key="TextTertiary" Color="#71717A" />

        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarNavItem" TargetType="RadioButton">
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                                           Foreground="{TemplateBinding Foreground}"
                                           FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}" />
                    <Setter Property="Background" Value="#1E2B3E" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2C2C2E" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Filter Pill Style -->
        <Style x:Key="FilterPill" TargetType="RadioButton">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{StaticResource BgInput}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBlue}" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#38393F" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ListBoxItem Style -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="OuterBorder" Background="{TemplateBinding Background}" CornerRadius="8" Margin="12,2" BorderThickness="1" BorderBrush="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="#25262B" />
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{StaticResource BorderMuted}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="#1E2B3E" />
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{StaticResource AccentBlue}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Control Button -->
        <Style x:Key="WindowControlBtn" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Content}" FontFamily="Segoe Fluent Icons" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D2D2D" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" Background="{TemplateBinding Background}" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="#3E3E42" CornerRadius="4" Margin="2,0" />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border Background="#555555" CornerRadius="4" Margin="1,0" />
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="{StaticResource BgSidebar}">
            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- App Logo -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <Border Width="24" Height="24" Background="{StaticResource AccentBlue}" CornerRadius="4" Margin="0,0,12,0">
                    <TextBlock Text="&#xEA37;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="RecentDock" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Nav Items -->
            <StackPanel Grid.Row="1" Margin="0,10">
                <RadioButton Content="All" IsChecked="True" Style="{StaticResource SidebarNavItem}" Tag="&#xE8B9;"/>
                <RadioButton Content="Favorites" Style="{StaticResource SidebarNavItem}" Tag="&#xE734;"/>
                <RadioButton Content="Recent Folders" Style="{StaticResource SidebarNavItem}" Tag="&#xE8B7;"/>
                <Separator Background="{StaticResource BorderMuted}" Margin="16,10" Height="1"/>
                <RadioButton Content="Documents" Style="{StaticResource SidebarNavItem}" Tag="&#xE8A5;"/>
                <RadioButton Content="Images" Style="{StaticResource SidebarNavItem}" Tag="&#xEB9F;"/>
                <RadioButton Content="Code" Style="{StaticResource SidebarNavItem}" Tag="&#xE943;"/>
            </StackPanel>

            <!-- Footer Settings -->
            <RadioButton Grid.Row="2" Content="Settings" Style="{StaticResource SidebarNavItem}" Tag="&#xE713;" Margin="0,0,0,20"/>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Column="1" Background="{StaticResource BgMain}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" /> <!-- Custom Title Bar Row -->
                <RowDefinition Height="Auto" /> <!-- Search Row -->
                <RowDefinition Height="Auto" /> <!-- Filter Row -->
                <RowDefinition Height="*" /> <!-- List Row -->
                <RowDefinition Height="40" /> <!-- Status Bar Row -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar Controls -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="&#xE921;" Style="{StaticResource WindowControlBtn}" Click="MinimizeBtn_Click"/>
                <Button Content="&#xE922;" Style="{StaticResource WindowControlBtn}" Click="MaximizeBtn_Click"/>
                <Button Content="&#xE8BB;" Click="CloseBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource WindowControlBtn}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Search Area -->
            <Grid Grid.Row="1" Margin="24,10,24,10">
                <Border Background="{StaticResource BgInput}" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource BorderMuted}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextTertiary}"/>
                        <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="White" VerticalContentAlignment="Center" FontSize="14" Padding="0,10"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 x:Name="SearchBox" KeyDown="SearchBox_KeyDown" />
                        <TextBlock Grid.Column="1" Text="Search recent files..." Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text.IsEmpty, ElementName=SearchBox}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0">
                            <TextBlock Text="Ctrl + Alt + R" Foreground="{StaticResource TextTertiary}" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Filter Area -->
            <Grid Grid.Row="2" Margin="24,0,24,10">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="All" IsChecked="True" Style="{StaticResource FilterPill}"/>
                    <RadioButton Content="Docs" Style="{StaticResource FilterPill}"/>
                    <RadioButton Content="Images" Style="{StaticResource FilterPill}"/>
                    <RadioButton Content="Code" Style="{StaticResource FilterPill}"/>
                    <RadioButton Content="Folders" Style="{StaticResource FilterPill}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Background="Transparent" BorderThickness="0" Padding="8,4" Foreground="{StaticResource TextSecondary}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Newest first" FontSize="12" Margin="0,0,8,0"/>
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe Fluent Icons" FontSize="8" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Content="&#xE8A9;" FontFamily="Segoe Fluent Icons" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- List Area -->
            <ListBox x:Name="ItemsList" Grid.Row="3" Background="Transparent" BorderThickness="0"
                     ItemsSource="{Binding ItemsView}"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="ItemsList_MouseDoubleClick"
                     MouseMove="ItemsList_MouseMove">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:RecentItemViewModel}">
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- File Icon Placeholder -->
                            <Border Grid.Column="0" Width="40" Height="40" Background="{StaticResource BgInput}" CornerRadius="6" Margin="0,0,16,0">
                                <TextBlock Text="📄" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- File Info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding RecentTimeDisplay}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding SizeDisplay}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding DisplayPath}" FontSize="11" Foreground="{StaticResource TextTertiary}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Action Buttons (Mockup: Open Folder, Pin, More) -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="&#xED25;" FontFamily="Segoe Fluent Icons" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextTertiary}" Width="32" Height="32"/>
                                <Button Content="&#xE718;" FontFamily="Segoe Fluent Icons" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextTertiary}" Width="32" Height="32"/>
                                <Button Content="&#xE712;" FontFamily="Segoe Fluent Icons" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextTertiary}" Width="32" Height="32"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Status Bar -->
            <Border Grid.Row="4" Background="#1C1C1E" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderMuted}" Padding="20,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#40C057" Margin="0,0,8,0"/>
                        <TextBlock Text="Ready" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,12,0"/>
                        <Separator Width="1" Height="12" Background="{StaticResource BorderMuted}" Margin="0,0,12,0"/>
                        <TextBlock Text="128 items" FontSize="12" Foreground="{StaticResource TextTertiary}"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <TextBlock Text="&#xE74A;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{StaticResource TextTertiary}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Navigate" FontSize="11" Foreground="{StaticResource TextTertiary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Border Background="{StaticResource BgInput}" Padding="4,1" CornerRadius="2" Margin="0,0,4,0">
                                <TextBlock Text="Enter" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                            </Border>
                            <TextBlock Text="Open" FontSize="11" Foreground="{StaticResource TextTertiary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE724;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{StaticResource TextTertiary}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Drag to share" FontSize="11" Foreground="{StaticResource TextTertiary}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
