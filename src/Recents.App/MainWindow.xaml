<Window x:Class="Recents.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Recents.App.ViewModels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Recents" Height="760" Width="1040" MinHeight="520" MinWidth="760"
        WindowStartupLocation="CenterScreen" 
        Topmost="True" ShowInTaskbar="False"
        Background="{StaticResource BgMain}" Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
        WindowStyle="None" AllowsTransparency="False"
        PreviewKeyDown="Window_PreviewKeyDown"
        SizeChanged="Window_SizeChanged"
        Closing="Window_Closing">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="8" ResizeBorderThickness="8" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ListBoxItem Style -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Header="Open" Command="{Binding OpenCommand}"/>
                        <MenuItem Header="Reveal in Explorer" Command="{Binding RevealCommand}"/>
                        <Separator/>
                        <MenuItem Header="Copy Full Path" Command="{Binding CopyPathCommand}"/>
                        <MenuItem Header="Copy File Name" Command="{Binding CopyFileNameCommand}"/>
                        <Separator/>
                        <MenuItem Header="Pin/Unpin" Command="{Binding TogglePinCommand}"/>
                        <Separator/>
                        <MenuItem Header="Remove Once" Command="{Binding RemoveOnceCommand}"/>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="OuterBorder" Background="{TemplateBinding Background}" CornerRadius="8" Margin="12,2" BorderThickness="1" BorderBrush="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{StaticResource RowHover}" />
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{StaticResource BorderMuted}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{StaticResource RowSelected}" />
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{StaticResource AccentBlue}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Control Button -->
        <Style x:Key="WindowControlBtn" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Content}" FontFamily="Segoe Fluent Icons" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHover}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" Background="{TemplateBinding Background}" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{StaticResource BgCard}" CornerRadius="4" Margin="2,0" />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border Background="{StaticResource RowHover}" CornerRadius="4" Margin="1,0" />
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="{StaticResource BgSidebar}">
            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- App Logo -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <Border Width="24" Height="24" Background="{StaticResource AccentBlue}" CornerRadius="4" Margin="0,0,12,0">
                    <TextBlock Text="&#xEA37;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="LogoText" Text="Recents" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Nav Items -->
            <StackPanel Grid.Row="1" Margin="0,10">
                <RadioButton Content="All Files" IsChecked="True" Style="{StaticResource SidebarNavItem}" Tag="&#xE8B9;" Checked="Nav_Checked"/>
                <RadioButton Content="Favorites" Style="{StaticResource SidebarNavItem}" Tag="&#xE734;" Checked="Nav_Checked"/>
                <RadioButton Content="Recent Folders" Style="{StaticResource SidebarNavItem}" Tag="&#xE8B7;" Checked="Nav_Checked"/>
                <Separator Background="{StaticResource BorderMuted}" Margin="16,10" Height="1"/>
                <RadioButton Content="Documents" Style="{StaticResource SidebarNavItem}" Tag="&#xE8A5;" Checked="Nav_Checked"/>
                <RadioButton Content="Images" Style="{StaticResource SidebarNavItem}" Tag="&#xEB9F;" Checked="Nav_Checked"/>
                <RadioButton Content="Code" Style="{StaticResource SidebarNavItem}" Tag="&#xE943;" Checked="Nav_Checked"/>
            </StackPanel>

            <!-- Footer Settings -->
            <RadioButton Grid.Row="2" Content="Settings" Style="{StaticResource SidebarNavItem}" Tag="&#xE713;" Margin="0,0,0,20" Checked="Nav_Checked"/>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Column="1" Background="{StaticResource BgMain}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" /> <!-- Custom Title Bar Row -->
                <RowDefinition Height="Auto" /> <!-- Search Row -->
                <RowDefinition Height="Auto" /> <!-- Filter Row -->
                <RowDefinition Height="*" /> <!-- List Row -->
                <RowDefinition Height="40" /> <!-- Status Bar Row -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar Controls -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="&#xE921;" Style="{StaticResource WindowControlBtn}" Click="MinimizeBtn_Click"/>
                <Button Content="&#xE922;" Style="{StaticResource WindowControlBtn}" Click="MaximizeBtn_Click"/>
                <Button Content="&#xE8BB;" Click="CloseBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource WindowControlBtn}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource ColorDanger}" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Search Area -->
            <Grid Grid.Row="1" Margin="24,10,24,10">
                <Border Background="{StaticResource BgInput}" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource BorderMuted}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextTertiary}"/>
                        <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}" VerticalContentAlignment="Center" FontSize="14" Padding="0,10"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 x:Name="SearchBox" KeyDown="SearchBox_KeyDown" />
                        <TextBlock Grid.Column="1" Text="Search recent files..." Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text.IsEmpty, ElementName=SearchBox}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0">
                            <TextBlock Text="{Binding HotkeyDisplay}" Foreground="{StaticResource TextTertiary}" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Filter Area -->
            <Grid Grid.Row="2" Margin="24,0,24,10">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="All Files" IsChecked="True" Style="{StaticResource FilterPill}" Checked="Chip_Checked" Tag="All"/>
                    <RadioButton Content="Documents" Style="{StaticResource FilterPill}" Tag="Documents" Checked="Chip_Checked"/>
                    <RadioButton Content="Images" Style="{StaticResource FilterPill}" Tag="Images" Checked="Chip_Checked"/>
                    <RadioButton Content="Code" Style="{StaticResource FilterPill}" Tag="Code" Checked="Chip_Checked"/>
                    <RadioButton Content="Folders" Style="{StaticResource FilterPill}" Tag="Folders" Checked="Chip_Checked"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Background="Transparent" BorderThickness="0" Padding="8,4" Foreground="{StaticResource TextSecondary}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                <EventSetter Event="Click" Handler="SortButton_Click"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SortLabel" Text="Newest first" FontSize="12" Margin="0,0,8,0"/>
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe Fluent Icons" FontSize="8" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Newest first" Click="SortItem_Click" Tag="RecentTime"/>
                                <MenuItem Header="Name A-Z" Click="SortItem_Click" Tag="DisplayName"/>
                                <!-- P1: Size and File Type sorting options hidden -->
                                <MenuItem Header="Size" Click="SortItem_Click" Tag="Size" Visibility="Collapsed"/>
                                <MenuItem Header="Classification" Click="SortItem_Click" Tag="ClassificationSource" Visibility="Collapsed"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="&#xE8A9;" FontFamily="Segoe Fluent Icons" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" Margin="8,0,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>

            <!-- List Area -->
            <Grid Grid.Row="3">
                <!-- Empty State -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasItems}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#xE9CE;" FontFamily="Segoe Fluent Icons" FontSize="48" Foreground="{StaticResource TextTertiary}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="No recent files found" FontSize="14" Foreground="{StaticResource TextTertiary}" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                        <Button Content="Clear filters"
                                Command="{Binding ClearFiltersCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                Padding="12,7" Margin="0,0,8,0"/>
                        <Button Content="Rebuild index"
                                Command="{Binding RebuildIndexCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                Padding="12,7"/>
                    </StackPanel>
                </StackPanel>

                <ListBox x:Name="ItemsList" Background="Transparent" BorderThickness="0"
                         SelectionMode="Extended"
                         ItemsSource="{Binding ItemsView}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseDoubleClick="ItemsList_MouseDoubleClick"
                         MouseMove="ItemsList_MouseMove">
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasItems}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:RecentItemViewModel}">
                        <Grid Margin="4" x:Name="ItemGrid">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                            <Setter Property="Opacity" Value="0.5" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open" Command="{Binding OpenCommand}"/>
                                    <MenuItem Header="Reveal in Explorer" Command="{Binding RevealCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="Copy Full Path" Command="{Binding CopyPathCommand}"/>
                                    <MenuItem Header="Copy File Name" Command="{Binding CopyFileNameCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="Pin/Unpin" Command="{Binding TogglePinCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="Remove Once" Command="{Binding RemoveOnceCommand}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>

                            <!-- File Icon -->
                            <Image Grid.Column="0" Source="{Binding Icon}" Width="40" Height="40" VerticalAlignment="Center" Margin="0,0,16,0"/>

                            <!-- File Info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <!-- 第一行：文件名 + 类型徽章 -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis" MaxWidth="320"/>
                                    <!-- PRD §6.7 文件类型徽章：仅当 ClassificationSource 非 Other 且非文件夹时显示 -->
                                    <Border CornerRadius="4" Background="{StaticResource AccentBlue}"
                                            Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center"
                                            Visibility="{Binding BadgeVisibility}">
                                        <TextBlock Text="{Binding ClassificationSource}" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding RecentTimeDisplay}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding SizeDisplay}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding DisplayPathShort}" ToolTip="{Binding DisplayPath}" FontSize="11" Foreground="{StaticResource TextTertiary}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Action Buttons (Open, Reveal, Pin, More) -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="&#xED25;" Command="{Binding OpenCommand}" 
                                        FontFamily="Segoe Fluent Icons" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextTertiary}" Width="32" Height="32">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                            <Setter Property="ToolTip" Value="Open"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="ToolTip" Value="{Binding OpenDisabledReason}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="&#xE81D;" Command="{Binding RevealCommand}"
                                        FontFamily="Segoe Fluent Icons" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextTertiary}" Width="32" Height="32">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                            <Setter Property="ToolTip" Value="Reveal in Explorer"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="ToolTip" Value="{Binding OpenDisabledReason}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="&#xE735;" ToolTip="Toggle Pin" Command="{Binding TogglePinCommand}"
                                        FontFamily="Segoe Fluent Icons" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextTertiary}" Width="32" Height="32">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Item.IsFavorite}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="&#xE712;" ToolTip="More Actions" Click="MoreButton_Click"
                                        FontFamily="Segoe Fluent Icons" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextTertiary}" Width="32" Height="32">
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            </Grid>
            
            <!-- Status Bar -->
            <Border Grid.Row="4" Background="{StaticResource BgCard}" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderMuted}" Padding="20,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{Binding Status.StatusColor}" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Status.StatusText}" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,12,0"/>
                        <Separator Width="1" Height="12" Background="{StaticResource BorderMuted}" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding Status.ItemCount}" FontSize="12" Foreground="{StaticResource TextTertiary}"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Status.KeyboardHint}" FontSize="11" Foreground="{StaticResource TextTertiary}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
