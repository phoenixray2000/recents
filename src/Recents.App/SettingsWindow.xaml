<Window x:Class="Recents.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:src="clr-namespace:Recents.App.Services.Sources"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Recents - Settings"
        Height="660" Width="860"
        MinHeight="560" MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgWindow}"
        Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
        WindowStyle="None"
        ResizeMode="CanResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="8" ResizeBorderThickness="8" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="WindowControlBtn" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Content}" FontFamily="Segoe Fluent Icons" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHover}" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsButton" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMuted}"/>
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
        </Style>

        <Style x:Key="PrimarySettingsButton" TargetType="Button" BasedOn="{StaticResource SettingsButton}">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMuted}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- Premium ComboBox Style -->
        <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="32" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" />
                                <TextBlock Grid.Column="1" Text="&#xE70D;" FontFamily="Segoe Fluent Icons" FontSize="10"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextTertiary}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource RowHover}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BorderMuted}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource RowSelected}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBlue}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMuted}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                          Style="{StaticResource ComboBoxToggleButton}" 
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="false" ClickMode="Press" />
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="12,3,32,3" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Fade" VerticalOffset="4">
                                <Border x:Name="DropDownBorder" Background="{StaticResource BgCard}" 
                                        BorderBrush="{StaticResource BorderMuted}" BorderThickness="1" 
                                        CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="Black" />
                                    </Border.Effect>
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource RowHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource RowSelected}"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="{StaticResource BgMain}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{StaticResource TextTertiary}" CornerRadius="4" Margin="3,2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,7"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SettingsTabItem" TargetType="TabItem">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                    <Setter Property="Background" Value="{StaticResource RowSelected}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHover}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource BgMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource AccentBlue}" BorderThickness="1" Background="{StaticResource BgMain}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource BgWindow}">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <Border Width="24" Height="24" Background="{StaticResource AccentBlue}" CornerRadius="4" Margin="0,0,12,0">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Settings" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Background="{StaticResource BgMain}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="{StaticResource BgTitleBar}">
                <TextBlock Text="Recents Settings" VerticalAlignment="Center" Margin="24,0,0,0"
                           Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="&#xE8BB;" Click="CloseBtn_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource WindowControlBtn}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource ColorDanger}" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <TabControl Grid.Row="1" Grid.ColumnSpan="2" TabStripPlacement="Left" Margin="-220,0,0,0" Background="{StaticResource BgMain}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource SettingsTabItem}"/>
                    <Style TargetType="TabPanel">
                        <Setter Property="Width" Value="220"/>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="General">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BgMain}">
                        <StackPanel Margin="244,24,24,24">
                            <TextBlock Text="General" Style="{StaticResource SectionTitle}"/>
                            <CheckBox Content="Launch at startup" IsChecked="{Binding LaunchAtStartup}"/>
                            <CheckBox Content="Hide when focus lost" IsChecked="{Binding HideOnFocusLost}"/>
                            <CheckBox Content="Always on top" IsChecked="{Binding AlwaysOnTop}"/>
                            <TextBlock Text="Close button behavior" Style="{StaticResource FieldLabel}" Margin="0,18,0,6"/>
                            <CheckBox Content="Hide to tray when closing" IsChecked="{Binding CloseToTray}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Hotkey">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BgMain}">
                        <StackPanel Margin="244,24,24,24" MaxWidth="560" HorizontalAlignment="Left">
                            <TextBlock Text="Hotkey" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="Current hotkey" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Hotkey, UpdateSourceTrigger=PropertyChanged}" 
                                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                     IsReadOnly="True"
                                     Margin="0,0,0,14"/>
                            <Button Content="Reset to default" Command="{Binding ResetHotkeyCommand}"
                                    Style="{StaticResource SettingsButton}" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Sources">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BgMain}">
                        <StackPanel Margin="244,24,24,24">
                            <TextBlock Text="Sources" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="System sources" Style="{StaticResource FieldLabel}"/>
                            <ItemsControl ItemsSource="{Binding SystemSources}" Margin="0,0,0,20">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderMuted}"
                                                BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34"/>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="2" Text="{Binding KindLabel}" Foreground="{StaticResource TextSecondary}"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Location}" Foreground="{StaticResource TextTertiary}" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Known folders" Style="{StaticResource FieldLabel}"/>
                            <ItemsControl ItemsSource="{Binding KnownSources}" Margin="0,0,0,20">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type src:SourceConfig}">
                                        <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding Enabled}"
                                                  Command="{Binding DataContext.SaveSourcesCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Custom paths" Style="{StaticResource FieldLabel}"/>
                            <ItemsControl ItemsSource="{Binding CustomSources}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type src:SourceConfig}">
                                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderMuted}"
                                                BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="Remove"
                                                        Command="{Binding DataContext.RemoveSourceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SettingsButton}"/>
                                                <CheckBox DockPanel.Dock="Left" IsChecked="{Binding Enabled}"
                                                          Command="{Binding DataContext.SaveSourcesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding Path}" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="Add Folder..." Command="{Binding AddFolderCommand}" Style="{StaticResource PrimarySettingsButton}"/>
                                <Button Content="Add Network Path..." Command="{Binding AddNetworkPathCommand}" Style="{StaticResource SettingsButton}"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="List">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BgMain}">
                        <StackPanel Margin="244,24,24,24" MaxWidth="560" HorizontalAlignment="Left">
                            <TextBlock Text="List" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="Max recent items" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding MaxRecentItemOptions}" SelectedItem="{Binding MaxRecentItems}"
                                      Width="180" HorizontalAlignment="Left" Margin="0,0,0,14"/>
                            <CheckBox Content="Show folders" IsChecked="{Binding ShowFolders}"/>
                            <TextBlock Text="Default sort" Style="{StaticResource FieldLabel}" Margin="0,18,0,6"/>
                            <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding DefaultSort}"
                                      Width="240" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Filters">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BgMain}">
                        <Grid Margin="244,24,24,24" MaxWidth="680" HorizontalAlignment="Left">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="100"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="120"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="90"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Filters" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Grid.Row="1" Text="Excluded extensions" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="2" Text="{Binding ExcludedExtensionsText, UpdateSourceTrigger=LostFocus}"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            <TextBlock Grid.Row="3" Text="Excluded paths" Style="{StaticResource FieldLabel}" Margin="0,14,0,6"/>
                            <TextBox Grid.Row="4" Text="{Binding ExcludedPathsText, UpdateSourceTrigger=LostFocus}"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            <TextBlock Grid.Row="5" Text="Excluded keywords" Style="{StaticResource FieldLabel}" Margin="0,14,0,6"/>
                            <TextBox Grid.Row="6" Text="{Binding ExcludedKeywordsText, UpdateSourceTrigger=LostFocus}"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Cache">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BgMain}">
                        <StackPanel Margin="244,24,24,24">
                            <TextBlock Text="Cache" Style="{StaticResource SectionTitle}"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Rebuild index" Command="{Binding RebuildIndexCommand}" Style="{StaticResource PrimarySettingsButton}"/>
                                <Button Content="Clear icon cache" Command="{Binding ClearIconCacheCommand}" Style="{StaticResource SettingsButton}"/>
                                <Button Content="Clear hidden items" Command="{Binding ClearHiddenItemsCommand}" Style="{StaticResource SettingsButton}"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="About">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BgMain}">
                        <StackPanel Margin="244,24,24,24" MaxWidth="680" HorizontalAlignment="Left">
                            <TextBlock Text="About" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="{Binding Version, StringFormat=Version {0}}" Margin="0,0,0,16"/>
                            <TextBlock Text="Settings path" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding SettingsPath}" TextWrapping="Wrap" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,14"/>
                            <TextBlock Text="Data path" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding DataPath}" TextWrapping="Wrap" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,14"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Open data folder" Command="{Binding OpenDataFolderCommand}" Style="{StaticResource PrimarySettingsButton}"/>
                                <Button Content="Open log folder" Command="{Binding OpenLogFolderCommand}" Style="{StaticResource SettingsButton}"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
    </Border>
</Window>
