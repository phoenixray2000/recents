<Window x:Class="Recents.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:src="clr-namespace:Recents.App.Services.Sources"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Settings" Height="600" Width="700" MinHeight="480" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgWindow}"
        Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
        WindowStyle="None"
        Icon="pack://application:,,,/Recents;component/Resources/Icons/AppIcon.ico"
        ResizeMode="CanResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="8" ResizeBorderThickness="8" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="WindowControlBtn" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Content}" FontFamily="Segoe Fluent Icons" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHover}" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsButton" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMuted}"/>
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
        </Style>

        <Style x:Key="PrimarySettingsButton" TargetType="Button" BasedOn="{StaticResource SettingsButton}">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMuted}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="HotkeyTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                    <Setter Property="Background" Value="{StaticResource RowSelected}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Premium ComboBox Style -->
        <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="32" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" />
                                <TextBlock Grid.Column="1" Text="&#xE70D;" FontFamily="Segoe Fluent Icons" FontSize="10"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextTertiary}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource RowHover}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BorderMuted}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource RowSelected}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBlue}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PremiumComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMuted}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                          Style="{StaticResource ComboBoxToggleButton}" 
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="false" ClickMode="Press" />
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="12,3,32,3" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Fade" VerticalOffset="4">
                                <Border x:Name="DropDownBorder" Background="{StaticResource BgCard}" 
                                        BorderBrush="{StaticResource BorderMuted}" BorderThickness="1" 
                                        CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="Black" />
                                    </Border.Effect>
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource RowHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource RowSelected}"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource PremiumComboBox}"/>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="{StaticResource BgMain}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{StaticResource TextTertiary}" CornerRadius="4" Margin="3,2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,7"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,12,0,8"/>
        </Style>

        <Style x:Key="SettingsTabItem" TargetType="TabItem">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource RowHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource RowSelected}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMuted}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource BgMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource AccentBlue}" BorderThickness="1" Background="{StaticResource BgMain}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar Area -->
            <Grid Grid.Row="0" Background="{StaticResource BgTitleBar}">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentBlue}" 
                           FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="24,0"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="&#xE8BB;" Click="CloseBtn_Click" ToolTip="Close settings">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource WindowControlBtn}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E81123"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main Content Area -->
            <TabControl Grid.Row="1" TabStripPlacement="Left" Background="{StaticResource BgMain}" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource SettingsTabItem}"/>
                    <Style TargetType="TabPanel">
                        <Setter Property="Width" Value="180"/>
                        <Setter Property="Background" Value="{StaticResource BgSidebar}"/>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="General">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BgMain}">
                        <StackPanel Margin="32,24" MaxWidth="560" HorizontalAlignment="Left">
                            <TextBlock Text="General" Style="{StaticResource SectionTitle}"/>
                            
                            <TextBlock Text="Startup &amp; Behavior" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource SettingsCard}">
                                <StackPanel>
                                    <CheckBox Content="Launch at startup" IsChecked="{Binding LaunchAtStartup}"/>
                                    <CheckBox Content="Start minimized" IsChecked="{Binding StartMinimized}"/>
                                    <CheckBox Content="Hide when focus lost" IsChecked="{Binding HideOnFocusLost}"/>
                                    <CheckBox Content="Always on top" IsChecked="{Binding AlwaysOnTop}"/>
                                    <CheckBox Content="Hide to tray when closing" IsChecked="{Binding CloseToTray}"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Quick Preview" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource SettingsCard}" Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding PreviewEnabled}"
                                              VerticalAlignment="Top" Margin="0,2,12,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Enable quick preview (Space)" 
                                                   Foreground="{StaticResource TextPrimary}" FontWeight="Medium" FontSize="13"/>
                                        <TextBlock Text="Press Space to preview supported files using WebView2 engine" 
                                                   Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Hotkey">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BgMain}">
                        <StackPanel Margin="32,24" MaxWidth="560" HorizontalAlignment="Left">
                            <TextBlock Text="Hotkey" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="Global Hotkey" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource SettingsCard}">
                                <StackPanel>
                                    <TextBlock Text="Press this hotkey from anywhere to show or hide Recents" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,12"/>
                                    <TextBox Text="{Binding Hotkey, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource HotkeyTextBoxStyle}"
                                             PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                             IsReadOnly="True"
                                             Margin="0,0,0,12"
                                             ToolTip="Click and press keys to change hotkey"/>
                                    <Button Content="Reset to default" Command="{Binding ResetHotkeyCommand}"
                                            Style="{StaticResource SettingsButton}" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Sources">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BgMain}">
                        <StackPanel Margin="32,24">
                            <TextBlock Text="Sources" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="System sources" Style="{StaticResource FieldLabel}"/>
                            <ItemsControl ItemsSource="{Binding SystemSources}" Margin="0,0,0,20">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderMuted}"
                                                BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,12,0" ToolTip="Enable/Disable source"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="14"/>
                                                    <TextBlock Text="{Binding Location}" Foreground="{StaticResource TextTertiary}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="2" Background="{StaticResource BgInput}" CornerRadius="4" Padding="8,2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding KindLabel}" Foreground="{StaticResource TextSecondary}" FontSize="10" FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Known folders" Style="{StaticResource FieldLabel}"/>
                            <ItemsControl ItemsSource="{Binding KnownSources}" Margin="0,0,0,20">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type src:SourceConfig}">
                                        <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding Enabled}" 
                                                  Command="{Binding DataContext.SaveSourcesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Margin="0,0,0,8"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Custom paths" Style="{StaticResource FieldLabel}"/>
                            <ItemsControl ItemsSource="{Binding CustomSources}" Margin="0,0,0,12">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type src:SourceConfig}">
                                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderMuted}"
                                                BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,12,0"
                                                          Command="{Binding DataContext.SaveSourcesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          ToolTip="Enable/Disable source"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="14"/>
                                                    <TextBlock Text="{Binding Path}" Foreground="{StaticResource TextTertiary}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Button Grid.Column="2" Content="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="12"
                                                        Command="{Binding DataContext.RemoveSourceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource ActionButtonStyle}" Width="32" Height="32" ToolTip="Remove source"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Button Content="Add folder" Command="{Binding AddFolderCommand}" Style="{StaticResource PrimarySettingsButton}"/>
                                <Button Content="Add network path" Command="{Binding AddNetworkPathCommand}" Style="{StaticResource SettingsButton}"/>
                            </StackPanel>

                            <TextBlock Text="Cache &amp; Index" Style="{StaticResource FieldLabel}"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Rebuild index" Command="{Binding RebuildIndexCommand}" Style="{StaticResource PrimarySettingsButton}"/>
                                <Button Content="Clear hidden items" Command="{Binding ClearHiddenItemsCommand}" Style="{StaticResource SettingsButton}"/>
                                <Button Content="Clear icon cache" Command="{Binding ClearIconCacheCommand}" Style="{StaticResource SettingsButton}"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="List">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BgMain}">
                        <StackPanel Margin="32,24" MaxWidth="560" HorizontalAlignment="Left">
                            <TextBlock Text="List" Style="{StaticResource SectionTitle}"/>
                            
                            <TextBlock Text="Display Preferences" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource SettingsCard}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Max recent items" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding MaxRecentItemOptions}" SelectedItem="{Binding MaxRecentItems}"
                                                  Style="{StaticResource PremiumComboBox}" Width="120" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Default sort order" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding SortOptions}" SelectedItem="{Binding DefaultSort}"
                                                  Style="{StaticResource PremiumComboBox}" Width="120" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Content Options" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource SettingsCard}">
                                <CheckBox Content="Show folders in list" IsChecked="{Binding ShowFolders}"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Filters">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BgMain}">
                        <Grid Margin="32,24" MaxWidth="680" HorizontalAlignment="Left">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="100"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="120"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="90"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Filters" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Grid.Row="1" Text="Excluded extensions" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="2" Text="{Binding ExcludedExtensionsText, UpdateSourceTrigger=LostFocus}"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            <TextBlock Grid.Row="3" Text="Excluded paths" Style="{StaticResource FieldLabel}" Margin="0,14,0,6"/>
                            <TextBox Grid.Row="4" Text="{Binding ExcludedPathsText, UpdateSourceTrigger=LostFocus}"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            <TextBlock Grid.Row="5" Text="Excluded keywords" Style="{StaticResource FieldLabel}" Margin="0,14,0,6"/>
                            <TextBox Grid.Row="6" Text="{Binding ExcludedKeywordsText, UpdateSourceTrigger=LostFocus}"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="About">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BgMain}">
                        <StackPanel Margin="32,24" MaxWidth="680" HorizontalAlignment="Left">
                            <TextBlock Text="About" Style="{StaticResource SectionTitle}"/>
                            
                            <Border Style="{StaticResource SettingsCard}" Padding="24">
                                <StackPanel>
                                    <TextBlock Text="Recents" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" FontSize="28" Margin="0,0,0,12"/>
                                    
                                    <TextBlock Text="A lightweight Windows recent-files launcher." Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="Medium"/>
                                    <TextBlock Text="Quickly find, preview, drag, and open your recent files." Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,4,0,24"/>
                                    
                                    <TextBlock Text="Version" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                    <TextBlock Text="0.1.0" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>
                                    
                                    <TextBlock Text="Privacy" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                    <StackPanel Margin="0,0,0,20">
                                        <TextBlock Text="• Runs locally." Foreground="{StaticResource TextSecondary}" Margin="0,2"/>
                                        <TextBlock Text="• Does not upload files." Foreground="{StaticResource TextSecondary}" Margin="0,2"/>
                                        <TextBlock Text="• Does not delete original files." Foreground="{StaticResource TextSecondary}" Margin="0,2"/>
                                    </StackPanel>
                                    
                                    <TextBlock Text="Repository" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                    <TextBlock Margin="0,0,0,32">
                                        <Hyperlink NavigateUri="https://github.com/phoenixray2000/recents" RequestNavigate="Hyperlink_RequestNavigate">
                                            <TextBlock Text="https://github.com/phoenixray2000/recents" Foreground="{StaticResource AccentBlue}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                    
                                    <Border BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                                        <TextBlock Text="© 2026 Recents" Foreground="{StaticResource TextTertiary}" FontSize="11" HorizontalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
