<Application x:Class="Recents.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Recents.App.ViewModels"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- Color Palette — PRD §7.4 Token（每条与 PRD 名称一一对应） -->
        <!-- Window / Panel Backgrounds -->
        <SolidColorBrush x:Key="BgWindow"    Color="#101216" />  <!-- WindowBackground -->
        <SolidColorBrush x:Key="BgTitleBar"  Color="#151922" />  <!-- TitleBarBackground -->
        <SolidColorBrush x:Key="BgSidebar"   Color="#141821" />  <!-- SidebarBackground：原#121214 已修正 -->
        <SolidColorBrush x:Key="BgMain"      Color="#191D26" />  <!-- PanelBackground：原#121214 已修正 -->
        <SolidColorBrush x:Key="BgCard"      Color="#202633" />  <!-- PanelElevated：原#1C1C1E 已修正 -->
        <SolidColorBrush x:Key="BgInput"     Color="#252A34" />  <!-- SearchBackground：原#2C2C2E 已修正 -->
        <!-- Row States -->
        <SolidColorBrush x:Key="RowBg"            Color="#191D26" />  <!-- RowBackground -->
        <SolidColorBrush x:Key="RowHover"          Color="#222836" />  <!-- RowHover -->
        <SolidColorBrush x:Key="RowSelected"       Color="#1E3556" />  <!-- RowSelected -->
        <SolidColorBrush x:Key="RowSelectedBorder" Color="#3B82F6" />  <!-- RowSelectedBorder -->
        <!-- Accent -->
        <SolidColorBrush x:Key="AccentBlue"        Color="#3B82F6" />  <!-- Accent：原#40C4FF 已修正 -->
        <SolidColorBrush x:Key="AccentHover"       Color="#60A5FA" />  <!-- AccentHover -->
        <!-- Divider / Border -->
        <SolidColorBrush x:Key="BorderMuted"       Color="#2B313D" />  <!-- Divider：原#2C2C2E 已修正 -->
        <!-- Text -->
        <SolidColorBrush x:Key="TextPrimary"       Color="#F3F4F6" />  <!-- PrimaryText：原#F8F9FA 已修正 -->
        <SolidColorBrush x:Key="TextSecondary"     Color="#A7ADBA" />  <!-- SecondaryText：原#ADB5BD 已修正 -->
        <SolidColorBrush x:Key="TextTertiary"      Color="#7E8491" />  <!-- TertiaryText：原#6C757D 已修正 -->
        <!-- Status -->
        <SolidColorBrush x:Key="ColorSuccess"      Color="#63C554" />  <!-- Success -->
        <SolidColorBrush x:Key="ColorWarning"      Color="#F5B642" />  <!-- Warning -->
        <SolidColorBrush x:Key="ColorDanger"       Color="#E15B64" />  <!-- Danger -->
        <SolidColorBrush x:Key="ColorDisabled"     Color="#5D6470" />  <!-- Disabled -->

        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarNavItem" TargetType="RadioButton">
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                <TextBlock x:Name="NavIcon"
                                           Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                                           Foreground="{TemplateBinding Foreground}"
                                           FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <ContentPresenter x:Name="NavLabel" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding DataContext.IsCompactSidebar, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <Setter TargetName="NavIcon" Property="Margin" Value="0"/>
                                <Setter TargetName="NavLabel" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}" />
                    <Setter Property="Background" Value="{StaticResource RowSelected}" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHover}" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Filter Pill Style -->
        <Style x:Key="FilterPill" TargetType="ToggleButton">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{StaticResource BgInput}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBlue}" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHover}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Padding" Value="4" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                    <Setter Property="Background" Value="{StaticResource RowHover}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHover}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentBlue}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{StaticResource BgInput}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderMuted}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="{StaticResource BgInput}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Padding" Value="12,7" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHover}" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource TextTertiary}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="SharedRecentItemTemplate" DataType="{x:Type vm:RecentItemViewModel}">
            <Grid Margin="4" x:Name="ItemGrid">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                <Setter Property="Opacity" Value="0.5" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open" Command="{Binding OpenCommand}"/>
                        <MenuItem Header="Open With..." Command="{Binding OpenWithCommand}"/>
                        <MenuItem Header="Reveal in Explorer" Command="{Binding RevealCommand}"/>
                        <Separator/>
                        <MenuItem Header="Copy Full Path" Command="{Binding CopyPathCommand}"/>
                        <MenuItem Header="Copy File Name" Command="{Binding CopyFileNameCommand}"/>
                        <Separator/>
                        <MenuItem Header="Pin/Unpin" Command="{Binding TogglePinCommand}"/>
                        <MenuItem Header="Hide from list" Command="{Binding HideFromListCommand}"/>
                        <Separator/>
                        <MenuItem Header="Remove Once" Command="{Binding RemoveOnceCommand}"/>
                    </ContextMenu>
                </Grid.ContextMenu>

                <!-- File Icon -->
                <Image Grid.Column="0" Source="{Binding Icon}" Width="40" Height="40" VerticalAlignment="Center" Margin="0,0,16,0" x:Name="FileIcon"/>

                <!-- File Info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="NameText" Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis" MaxWidth="320"/>
                        <Border CornerRadius="4" Background="{StaticResource AccentBlue}"
                                Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center"
                                Visibility="{Binding BadgeVisibility}">
                            <TextBlock Text="{Binding ClassificationSource}" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <StackPanel x:Name="DetailsStack" Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="{Binding RecentTimeDisplay}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding SizeDisplay}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding DisplayPathShort}" ToolTip="{Binding DisplayPath}" FontSize="11" Foreground="{StaticResource TextTertiary}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&#xED25;" Command="{Binding OpenCommand}" 
                            FontFamily="Segoe Fluent Icons" Style="{StaticResource ActionButtonStyle}" Width="32" Height="32" ToolTip="Open"/>
                    <Button Content="&#xE81D;" Command="{Binding RevealCommand}"
                            FontFamily="Segoe Fluent Icons" Style="{StaticResource ActionButtonStyle}" Width="32" Height="32" ToolTip="Reveal in Explorer"/>
                    <Button Content="&#xE735;" Command="{Binding TogglePinCommand}"
                            FontFamily="Segoe Fluent Icons" Width="32" Height="32" ToolTip="Toggle Pin">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Item.IsFavorite}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding DataContext.CurrentDensity, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="Compact">
                    <Setter TargetName="ItemGrid" Property="Margin" Value="4,0"/>
                    <Setter TargetName="FileIcon" Property="Width" Value="24"/>
                    <Setter TargetName="FileIcon" Property="Height" Value="24"/>
                    <Setter TargetName="FileIcon" Property="Margin" Value="0,0,12,0"/>
                    <Setter TargetName="FileIcon" Property="Source" Value="{Binding SmallIcon}"/>
                    <Setter TargetName="NameText" Property="FontSize" Value="12"/>
                    <Setter TargetName="DetailsStack" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Application.Resources>
</Application>
